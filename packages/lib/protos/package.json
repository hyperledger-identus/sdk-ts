{
  "name": "@hyperledger/identus-protos",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "protos": "npm run protos:node && npm run protos:common && npx tsc -p tsconfig.lib.json",
    "protos:node": "protoc -I=src --proto_path=src --ts_out=src  src/node_models.proto",
    "protos:common": "protoc -I=src --proto_path=src --ts_out=src  src/common_models.proto"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./build/node_models.d.ts",
        "default": "./build/node_models.js"
      }
    }
  },
  "module": "./build/node_models.js",
  "types": "./build/node_models.d.ts",
  "files": [
    "build",
    "src"
  ],
  "devDependencies": {
    "@types/google-protobuf": "^3.15.6",
    "protoc-gen-ts": "^0.8.7"
  },
  "dependencies": {
    "google-protobuf": "^3.21.2"
  }
}
