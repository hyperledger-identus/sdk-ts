{
  "name": "identus",
  "version": "7.0.0",
  "private": true,
  "scripts": {
    "build": "npx nx run-many --targets=build --all",
    "build:clean": "npm run clean && npx nx run-many --targets=build --all --skip-nx-cache",
    "clean": "npm run clean:generated && npm run clean:build && npm run clean:reset",
    "clean:reset": "npx nx reset",
    "clean:generated": "find packages g -name generated -type d -not -path '*/node_modules/*' -exec rm -rf {} + 2>/dev/null; echo 'All generated folders cleaned'",
    "clean:build": "find packages g -name build -type d -not -path '*/node_modules/*' -exec rm -rf {} + 2>/dev/null; echo 'All build folders cleaned'",
    "test": "nx run-many --target=test",
    "coverage": "nx run-many --target=test -- --coverage",
    "lint": "nx run-many --target=lint",
    "lint:fix": "nx run-many --target=lint -- --fix"
  },
  "description": "Identus SDK - Typescript",
  "author": "IOHK",
  "repository": {
    "type": "git",
    "url": "https://github.com/hyperledger-identus/sdk-ts.git"
  },
  "license": "Apache-2.0",
  "keywords": [],
  "workspaces": [
    "packages/lib/*",
    "packages/shared/*",
    "packages/wasm/*",
    "integration-tests/*"
  ],
  "devDependencies": {
    "@eslint/eslintrc": "3",
    "@nx/vite": "22.4.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@swc/core": "^1.11.24",
    "@trust0/identus-store": "^1.0.0",
    "@trust0/ridb": "^1.5.0",
    "@trust0/ridb-core": "^1.7.0",
    "@types/google-protobuf": "^3.15.6",
    "@types/jsonld": "^1.5.14",
    "@types/node": "^22",
    "@types/pako": "^2.0.3",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vitest/browser": "^3.1.1",
    "@vitest/coverage-v8": "^3.1.1",
    "conventional-changelog-conventionalcommits": "^9.0.0",
    "eslint": "^9.26.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-jest": "^28.11.0",
    "husky": "^9.0.11",
    "jsdom": "^24.1.0",
    "nx": "22.4.4",
    "prettier": "^3.5.3",
    "protoc-gen-ts": "^0.8.7",
    "semantic-release": "^25.0.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "@trust0/identus-store": "^2.0.0",
    "@types/node": "^25.5.0",
    "multiformats": "^13.4.2"
  },
  "peerDependencies": {
    "@types/elliptic": "^6.4.16",
    "buffer": "^6.0.3",
    "core-js": "^3.32.2",
    "elliptic": "^6.5.4",
    "jsdom": "^24.1.0"
  },
  "overrides": {
    "ws": "^8.17.1"
  },
  "packageManager": "yarn@4.9.1+sha512.f95ce356460e05be48d66401c1ae64ef84d163dd689964962c6888a9810865e39097a5e9de748876c2e0bf89b232d583c33982773e9903ae7a76257270986538"
}