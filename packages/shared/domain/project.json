{
  "projectType": "library",
  "implicitDependencies": [
    "@hyperledger/identus-protos"
  ],
  "tags": [
    "scope:building-block"
  ],
  "targets": {
    "lint": {},
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.test.json",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config=vitest.config.js --coverage",
        "cwd": "{projectRoot}"
      }
    },
    "test-watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest watch --config=vitest.config.js",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/build"
      ],
      "options": {
        "command": "tsup",
        "cwd": "{projectRoot}"
      }
    }
  }
}