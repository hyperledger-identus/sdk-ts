{
  "extends": "@hyperledger/identus-wasm-config/tsconfig.wasm.json",
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "docs/typedoc",
    "coverage"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@hyperledger/identus-didcomm-wasm": [
        "./generated/identus-didcomm"
      ],
      "@hyperledger/identus-didcomm-wasm/*": [
        "./generated/*"
      ]
    }
  }
}