{
  "name": "@hyperledger/identus-sdk",
  "version": "7.0.0",
  "description": "Identus SDK - Typescript",
  "type": "module",
  "main": "./build/index.cjs",
  "module": "./build/index.js",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "require": "./build/index.cjs",
      "default": "./build/index.js"
    },
    "./plugins/anoncreds": {
      "types": "./build/plugins/internal/anoncreds/index.d.ts",
      "import": "./build/plugins/internal/anoncreds/index.js",
      "require": "./build/plugins/internal/anoncreds/index.cjs",
      "default": "./build/plugins/internal/anoncreds/index.js"
    },
    "./plugins/didcomm": {
      "types": "./build/plugins/internal/didcomm/index.d.ts",
      "import": "./build/plugins/internal/didcomm/index.js",
      "require": "./build/plugins/internal/didcomm/index.cjs",
      "default": "./build/plugins/internal/didcomm/index.js"
    },
    "./plugins/oidc": {
      "types": "./build/plugins/internal/oidc/index.d.ts",
      "import": "./build/plugins/internal/oidc/index.js",
      "require": "./build/plugins/internal/oidc/index.cjs",
      "default": "./build/plugins/internal/oidc/index.js"
    },
    "./plugins/dif": {
      "types": "./build/plugins/internal/dif/index.d.ts",
      "import": "./build/plugins/internal/dif/index.js",
      "require": "./build/plugins/internal/dif/index.cjs",
      "default": "./build/plugins/internal/dif/index.js"
    },
    "./plugins/oea": {
      "types": "./build/plugins/internal/oea/index.d.ts",
      "import": "./build/plugins/internal/oea/index.js",
      "require": "./build/plugins/internal/oea/index.cjs",
      "default": "./build/plugins/internal/oea/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "plugins/anoncreds": [
        "./build/plugins/internal/anoncreds/index.d.ts"
      ],
      "plugins/didcomm": [
        "./build/plugins/internal/didcomm/index.d.ts"
      ],
      "plugins/oidc": [
        "./build/plugins/internal/oidc/index.d.ts"
      ],
      "plugins/dif": [
        "./build/plugins/internal/dif/index.d.ts"
      ],
      "plugins/oea": [
        "./build/plugins/internal/oea/index.d.ts"
      ]
    }
  },
  "types": "./build/index.d.ts",
  "files": [
    "build/**/*",
    "README.MD",
    "preinstall.sh",
    "postinstall.sh",
    "patches/*.patch"
  ],
  "browserslist": [
    "last 2 chrome version",
    "last 2 firefox version",
    "last 2 safari version",
    "last 2 edge version"
  ],
  "scripts": {
    "prepare": "npx husky",
    "lint": "npx eslint ."
  },
  "author": "IOHK",
  "repository": {
    "type": "git",
    "url": "https://github.com/hyperledger-identus/sdk-ts.git"
  },
  "license": "Apache-2.0",
  "keywords": [],
  "devDependencies": {
    "@trust0/identus-store": "^2.0.0",
    "@trust0/ridb": "^1.5.41",
    "@trust0/ridb-core": "^1.7.36",
    "@types/jsonld": "^1.5.14",
    "@types/node": "^22",
    "@types/pako": "^2.0.3",
    "husky": "^9.0.11",
    "jsdom": "^24.1.0",
    "prettier": "^3.5.3",
    "protoc-gen-ts": "^0.8.7",
    "tsup": "^8.4.0",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typedoc-plugin-rename-defaults": "^0.7.3",
    "typedoc-theme-hierarchy": "^6.0.0",
    "typescript": "^5.8.3",
    "uuid": "^13.0.0"
  },
  "dependencies": {
    "@hyperledger/identus-apollo": "^1.4.5",
    "@mdx-js/mdx": "^3.1.1",
    "@noble/ciphers": "^0.6.0",
    "@scure/bip39": "^1.1.1",
    "@sd-jwt/sd-jwt-vc": "^0.7.1",
    "@sinclair/typebox": "^0.32.31",
    "@stablelib/sha256": "^1.0.1",
    "@stablelib/uuid": "^1.0.2",
    "bn.js": "^5.2.1",
    "did-jwt": "^8.0.4",
    "did-resolver": "^4.1.0",
    "google-protobuf": "^3.21.2",
    "hash.js": "1.1.7",
    "isows": "^1.0.3",
    "jsonld": "^9.0.0",
    "multiformats": "^13.4.2",
    "pako": "^2.1.0",
    "patch-package": "^8.0.0",
    "postinstall-postinstall": "^2.1.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "typedoc-plugin-md": "^0.7.1",
    "unified": "^11.0.5",
    "vfile": "^6.0.3",
    "ws": "^8.17.1"
  },
  "peerDependencies": {
    "@types/elliptic": "^6.4.16",
    "buffer": "^6.0.3",
    "core-js": "^3.32.2",
    "elliptic": "^6.5.4",
    "jsdom": "^24.1.0"
  },
  "overrides": {
    "ws": "^8.17.1"
  }
}
