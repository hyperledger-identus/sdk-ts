{
  "projectType": "library",
  "tags": [
    "scope:building-block"
  ],
  "targets": {
    "lint": {},
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.test.json",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config=vitest.config.js --coverage",
        "cwd": "{projectRoot}"
      }
    },
    "test-watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest watch --config=vitest.config.js",
        "cwd": "{projectRoot}"
      }
    },
    "build:protos": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/src/**/*.proto",
        "{projectRoot}/tsup.config.ts",
        "{projectRoot}/tsconfig.lib.json"
      ],
      "outputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/build"
      ],
      "options": {
        "command": "npm run protos",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "dependsOn": [
        "build:protos"
      ],
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/tsup.config.ts",
        "{projectRoot}/tsconfig.lib.json"
      ],
      "outputs": [
        "{projectRoot}/build"
      ],
      "options": {
        "command": "tsup && tsc -p tsconfig.lib.json",
        "cwd": "{projectRoot}"
      }
    }
  }
}